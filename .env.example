FITBIT_CLIENT_ID=your_client_id
FITBIT_CLIENT_SECRET=your_client_secret
FITBIT_REDIRECT_URI=http://127.0.0.1:8765/callback
COACH_DB_PATH=coach.db
COACH_USER_SLUG=default
ZEPBOUND_SHEET_URL=https://docs.google.com/spreadsheets/d/your-sheet-id/edit?gid=0#gid=0
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional one-time migration inputs for older local installs:
FITBIT_TOKEN_PATH=.fitbit_tokens.json
COACH_INTERACTION_LOG_PATH=coach_interactions.jsonl
